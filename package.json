{
  "name": "vue-mail-editor",
  "version": "1.2.0",
  "type": "module",
  "description": "A customizable, extensible drag-and-drop email template editor for Vue 3.",
  "license": "MIT",
  "author": "csesumonpro <hello@cleancodewithsumon.com>",
  "homepage": "https://csesumonpro.github.io/vue-mail-editor/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csesumonpro/vue-mail-editor.git"
  },
  "bugs": {
    "url": "https://github.com/csesumonpro/vue-mail-editor/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "email",
    "email-editor",
    "email-template",
    "email-builder",
    "drag-and-drop",
    "wysiwyg",
    "html-email",
    "newsletter"
  ],
  "files": [
    "dist",
    "LICENSE"
  ],
  "main": "./dist/vue-mail-editor.js",
  "module": "./dist/vue-mail-editor.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-mail-editor.js"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite --config vite.playground.config.ts",
    "build": "vue-tsc --noEmit && vite build",
    "build:playground": "vue-tsc --noEmit && vite build --config vite.playground.config.ts",
    "preview": "vite preview --config vite.playground.config.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-color": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-text-style": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@tiptap/vue-3": "^2.27.2",
    "js-beautify": "^1.15.4",
    "lucide-vue-next": "^0.460.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^22.19.19",
    "@vitejs/plugin-vue": "^5.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
